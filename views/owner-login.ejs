<%- include('./partials/header') %>
    <% if (typeof error !== 'undefined' && error.length > 0) { %>
        <div class="fixed top-20 left-1/2 -translate-x-1/2 p-3 rounded-xl bg-red-500 z-30 shadow-lg">
            <span class="inline-block mt-1 mb-1 text-white"><%= error %></span>
        </div>
    <% } %>
    <main class="pt-28 pb-10 px-4 md:px-10">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-6">
            <section class="rounded-3xl bg-ink text-white p-8 md:p-10 shadow-2xl overflow-hidden relative">
                <h1 class="text-4xl font-display">Owner Console</h1>
                <p class="text-white/70 mt-2">Manage products, pricing, and storefront visuals from one place.</p>

                <div class="grid grid-cols-2 gap-3 mt-7">
                    <img class="h-36 w-full object-cover rounded-2xl" src="/images/2bag.png" alt="Bag 2">
                    <img class="h-36 w-full object-cover rounded-2xl" src="/images/4bag.png" alt="Bag 4">
                    <img class="h-36 w-full object-cover rounded-2xl" src="/images/6bag.png" alt="Bag 6">
                    <img class="h-36 w-full object-cover rounded-2xl" src="/images/7bag.png" alt="Bag 7">
                </div>
            </section>

            <section class="grid gap-5">
                <div class="rounded-3xl bg-white/95 border border-black/5 p-6 md:p-7 shadow-lg">
                    <h4 class="text-2xl font-display mb-4">Admin Access</h4>
                    <form class="space-y-3" action="/owners/login" method="post">
                        <input class="block bg-zinc-100 w-full px-4 py-3 border rounded-xl border-zinc-200" type="email" placeholder="Email" name="email">
                        <input class="block bg-zinc-100 w-full px-4 py-3 border rounded-xl border-zinc-200" type="password" placeholder="Password" name="password">
                        <input class="w-full px-5 py-3 rounded-xl bg-caramel text-white" type="submit" value="Login">
                    </form>
                </div>

                <!-- <div class="rounded-3xl bg-white/95 border border-black/5 p-6 md:p-7 shadow-lg">
                    <h4 class="text-2xl font-display mb-4">Create Owner</h4>
                    <form class="space-y-3" action="/owners/create" method="post">
                        <input class="block bg-zinc-100 w-full px-4 py-3 border rounded-xl border-zinc-200" type="text" placeholder="Full Name" name="fullName">
                        <input class="block bg-zinc-100 w-full px-4 py-3 border rounded-xl border-zinc-200" type="email" placeholder="Email" name="email">
                        <input class="block bg-zinc-100 w-full px-4 py-3 border rounded-xl border-zinc-200" type="password" placeholder="Password" name="password">
                        <input class="w-full px-5 py-3 rounded-xl bg-ink text-white" type="submit" value="Create Owner">
                    </form>
                </div> -->
            </section>
        </div>
    </main>
    <%- include('./partials/footer') %>
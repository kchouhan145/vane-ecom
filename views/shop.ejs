<%- include('./partials/header') %>
    <main class="pt-28 pb-10 px-4 md:px-10">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-4 gap-6">
            <aside class="lg:col-span-1">
                <div class="rounded-3xl bg-white/90 border border-black/5 p-5 shadow-md sticky top-28">
                    <h2 class="text-xl font-display">Shop Filters</h2>
                    <form action="/shop" class="mt-4">
                        <label class="text-sm text-black/70">Sort by</label>
                        <select onchange="this.form.submit()" class="mt-1 w-full border border-zinc-300 rounded-xl px-3 py-2 bg-white" name="sortby">
                            <option value="popular">Popular</option>
                            <option value="newest">Newest</option>
                        </select>
                    </form>

                    <div class="mt-6 text-sm space-y-2 text-black/70">
                        <p>New Collection</p>
                        <p>All Products</p>
                        <p>Discounted Products</p>
                        <p>In Stock</p>
                    </div>

                    <img class="mt-6 rounded-2xl h-40 w-full object-cover" src="/images/5bag.png" alt="Featured bag">
                </div>
            </aside>

            <section class="lg:col-span-3">
                <div class="flex items-end justify-between mb-4">
                    <h1 class="text-3xl font-display">Explore Bags</h1>
                    <p class="text-sm text-black/60"><%= products.length %> items</p>
                </div>

                <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-5">
                    <% products.forEach(function(product){ %>
                    <article class="rounded-2xl overflow-hidden border border-black/5 bg-white/95 shadow-md hover:shadow-xl transition-shadow">
                        <div class="h-56 flex items-center justify-center" style="background-color: <%= product.bgcolor || '#f4f4f5' %>;">
                            <img class="h-44 object-contain" src="/images/<%= product.image || product.imgae || '1bag.png' %>" alt="<%= product.name %>">
                        </div>
                        <div class="p-4 flex items-center justify-between" style="background-color: <%= product.panelcolor || '#ffffff' %>; color: <%= product.textcolor || '#111827' %>;">
                            <div>
                                <h3 class="font-medium"><%= product.name %></h3>
                                <h4 class="text-sm">₹ <%= product.price %></h4>
                            </div>
                            <form action="/users/cart/add/<%= product._id %>" method="post">
                                <button class="w-9 h-9 flex items-center justify-center rounded-full bg-black text-white" type="submit">
                                    <i class="ri-shopping-bag-line"></i>
                                </button>
                            </form>
                        </div>
                    </article>
                    <% }) %>
                </div>

                <% if (products.length === 0) { %>
                <div class="rounded-2xl bg-white/80 border border-black/5 p-8 text-center text-black/60">No products yet. Add one from Admin.</div>
                <% } %>
            </section>
        </div>
    </main>
    <%- include('./partials/footer') %>
<%- include('./partials/header') %>

<% if (typeof error !== 'undefined' && error.length > 0) { %>
    <div class="fixed top-20 left-1/2 -translate-x-1/2 p-3 rounded-xl bg-red-500 z-30 shadow-lg">
        <span class="inline-block mt-1 mb-1 text-white"><%= error %></span>
    </div>
<% } %>

<main class="pt-28 pb-10 px-4 md:px-10">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-6">
        <section class="rounded-3xl bg-white/95 border border-black/5 p-6 md:p-8 shadow-lg">
            <h1 class="text-3xl font-display">User Login</h1>
            <p class="text-sm text-black/60 mt-1">Welcome back to Vane.</p>

            <form class="mt-6 space-y-3" autocomplete="off" action="/users/login" method="post">
                <input class="bg-zinc-100 block w-full px-4 py-3 rounded-xl border border-zinc-200" type="email" placeholder="Email" name="email">
                <input class="bg-zinc-100 block w-full px-4 py-3 rounded-xl border border-zinc-200" type="password" placeholder="Password" name="password">
                <input class="w-full px-5 py-3 rounded-xl bg-ink text-white font-medium cursor-pointer" type="submit" value="Login">
            </form>

            <a href="/" class="mt-4 inline-block text-sm text-caramel">Create new account</a>
        </section>

        <section class="rounded-3xl bg-ink text-white p-6 md:p-8 shadow-2xl">
            <h2 class="text-3xl font-display">Beyond the trend</h2>
            <p class="text-white/70 mt-2">Premium bags with utility, texture, and statement silhouettes.</p>

            <div class="mt-6 grid grid-cols-2 gap-3">
                <img class="h-32 w-full object-cover rounded-2xl" src="/images/1bag.png" alt="Bag 1">
                <img class="h-32 w-full object-cover rounded-2xl" src="/images/5bag.png" alt="Bag 5">
                <img class="h-32 w-full object-cover rounded-2xl" src="/images/6bag.png" alt="Bag 6">
                <img class="h-32 w-full object-cover rounded-2xl" src="/images/7bag.png" alt="Bag 7">
            </div>
        </section>
    </div>
</main>

<%- include('./partials/footer') %>

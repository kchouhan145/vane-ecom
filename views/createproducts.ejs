<%- include('./partials/header') %>

    <% if (typeof success !== 'undefined' && success.length > 0) { %>
        <div class="fixed top-20 left-1/2 -translate-x-1/2 p-3 rounded-xl bg-emerald-600 z-30 shadow-lg">
            <span class="inline-block mt-1 mb-1 text-white">
                <%= success %>
            </span>
        </div>
        <% } %>

            <main class="pt-28 pb-10 px-4 md:px-10">
                <div class="max-w-7xl mx-auto grid lg:grid-cols-4 gap-6">
                    <aside class="lg:col-span-1">
                        <div class="rounded-3xl bg-white/90 border border-black/5 p-5 shadow-md sticky top-28">
                            <h2 class="text-xl font-display">Create Product</h2>
                            <div class="mt-4 space-y-2 text-sm">
                                <a class="block px-3 py-2 rounded-xl bg-zinc-100" href="/owners/admin">All Products</a>
                                <a class="block px-3 py-2 rounded-xl bg-black text-white" href="/owners/create">Create New Product</a>
                            </div>

                            <div class="mt-5 grid grid-cols-2 gap-2">
                                <img class="h-20 w-full object-cover rounded-xl" src="/images/1bag.png" alt="Bag 1">
                                <img class="h-20 w-full object-cover rounded-xl" src="/images/2bag.png" alt="Bag 2">
                                <img class="h-20 w-full object-cover rounded-xl" src="/images/4bag.png" alt="Bag 4">
                                <img class="h-20 w-full object-cover rounded-xl" src="/images/6bag.png" alt="Bag 6">
                            </div>
                        </div>
                    </aside>

                    <section class="lg:col-span-3 rounded-3xl bg-white/95 border border-black/5 p-6 md:p-8 shadow-lg">
                        <h1 class="text-3xl font-display mb-1">Create New Product</h1>
                        <p class="text-sm text-black/60 mb-6">Upload a product image from your local machine and set your style colors.</p>

                        <form class="space-y-6" autocomplete="off" action="/products/create" method="post" enctype="multipart/form-data">
                            <div class="grid md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block mb-2 font-medium">Product Image</label>
                                    <input name="image" type="file" class="w-full border border-zinc-300 bg-white rounded-xl px-3 py-2">
                                </div>
                                <div>
                                    <label class="block mb-2 font-medium">Product Name</label>
                                    <input name="name" type="text" placeholder="Example: Urban Tote" class="w-full border border-zinc-300 rounded-xl px-4 py-3">
                                </div>
                            </div>

                            <div class="grid md:grid-cols-3 gap-4">
                                <input name="price" type="text" placeholder="Product Price" class="border border-zinc-300 rounded-xl px-4 py-3">
                                <input name="discount" type="text" placeholder="Discount Price" class="border border-zinc-300 rounded-xl px-4 py-3">
                                <input name="bgcolor" type="text" placeholder="Background Color (#f4f4f5)" class="border border-zinc-300 rounded-xl px-4 py-3">
                                <input name="panelcolor" type="text" placeholder="Panel Color (#ffffff)" class="border border-zinc-300 rounded-xl px-4 py-3 md:col-span-1">
                                <input name="textcolor" type="text" placeholder="Text Color (#111827)" class="border border-zinc-300 rounded-xl px-4 py-3 md:col-span-1">
                            </div>

                            <input class="px-6 py-3 rounded-xl bg-caramel text-white font-medium cursor-pointer" type="submit" value="Create Product">
                        </form>
                    </section>
                </div>
            </main>
            <%- include('./partials/footer') %>